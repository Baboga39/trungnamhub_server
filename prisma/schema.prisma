generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



enum DocumentStatus {
  PENDING
  NEED_REVISION
  APPROVED
}

enum ApprovalAction {
  APPROVE
  REJECT
  RESUBMIT
}

enum ApprovalTokenStatus {
  PENDING
  APPROVED
  REJECTED
}


model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  startYear DateTime?
  sumEvent  Int?
  role      String    @default("user")
  createdAt DateTime  @default(now())

  members           Member[]           @relation("MemberOwner")
  createdMembers    Member[]           @relation("MemberCreator")
  attendancesMarked Attendance[]       @relation("MarkedBy")
  permissions       ScreenPermission[]
  gradeCategories   GradeCategory[]
  approvedDocuments Document[]         @relation("ApprovedBy")

  sessionsCreated Session[]

  active            Boolean              @default(true)
  activitiesMarked  ActivityAttendance[] @relation("MarkedBy")
  activitiesCreated Activity[]
  approvals         Approval[]
  documents         Document[]

  @@index([role])
  @@index([active])
}

model Member {
  id         Int       @id @default(autoincrement())
  name       String
  birthDate  DateTime?
  gender     String?
  parish     String?
  church     String?
  startYear  Int?
  fatherName String?
  motherName String?
  address    String?
  contact    String?
  active     Boolean   @default(true)
  userId     Int?
  user       User?     @relation("MemberOwner", fields: [userId], references: [id])
  branch     String?

  createdById Int?
  createdBy   User? @relation("MemberCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendances         Attendance[]
  grades              Grade[]
  activityAttendances ActivityAttendance[]
  statusHistory       MemberStatusHistory[]

  @@index([userId])
  @@index([createdById])
  @@index([active])
}

model Attendance {
  id     Int      @id @default(autoincrement())
  date   DateTime
  status String
  note   String?

  memberId Int
  member   Member @relation(fields: [memberId], references: [id])

  sessionId Int?
  session   Session? @relation(fields: [sessionId], references: [id])

  markedById Int?
  markedBy   User? @relation("MarkedBy", fields: [markedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, memberId])
  @@index([memberId])
  @@index([date])
}

model Grade {
  id            Int           @id @default(autoincrement())
  score         Float
  memberId      Int
  mMember       Member        @relation(fields: [memberId], references: [id])
  createdAt     DateTime      @default(now())
  categoryId    Int
  activityScore Float?
  category      GradeCategory @relation(fields: [categoryId], references: [id])
  year          Int
  quarter       Int

  @@unique([memberId, categoryId, year, quarter])
  @@index([memberId])
}

model GradeCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  weight      Float
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  createdById Int
  createdBy   User     @relation(fields: [createdById], references: [id])
  grades      Grade[]

  @@index([createdById])
}

model ScreenPermission {
  id        Int      @id @default(autoincrement())
  screenId  String
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([screenId, userId])
}

model Session {
  id          Int          @id @default(autoincrement())
  date        DateTime     @unique
  createdById Int
  createdBy   User         @relation(fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())
  attendances Attendance[]

  @@index([createdById])
}

model Activity {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  year        Int
  quarter     Int
  date        DateTime

  attendances ActivityAttendance[]
  createdById Int
  createdBy   User @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
  @@index([date])
}

model ActivityAttendance {
  id     Int     @id @default(autoincrement())
  status String?
  note   String?

  activityId Int
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  memberId Int
  member   Member @relation(fields: [memberId], references: [id])

  markedById Int?
  markedBy   User? @relation("MarkedBy", fields: [markedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([activityId, memberId])
  @@index([memberId])
  @@index([activityId])
}

model MemberStatusHistory {
  id       Int    @id @default(autoincrement())
  memberId Int
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  status Boolean
  date   DateTime

  note String?

  createdAt DateTime @default(now())

  @@index([memberId])
}

model Document {
  id      Int    @id @default(autoincrement())
  title   String
  fileUrl String
  version Int    @default(1)

  status DocumentStatus @default(PENDING)

  createdById Int
  createdBy   User @relation(fields: [createdById], references: [id])

  approvedById Int?
  approvedBy   User? @relation("ApprovedBy", fields: [approvedById], references: [id])

  approvals Approval[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([createdById])
}

model Approval {
  id Int @id @default(autoincrement())

  documentId Int
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  reviewerId Int
  reviewer   User @relation(fields: [reviewerId], references: [id])

  action  ApprovalAction
  comment String?

  version Int
  fileUrl String

  createdAt DateTime @default(now())

  @@index([documentId, version, action])
  @@index([documentId, createdAt])
}

model ApprovalToken {
  id         Int    @id @default(autoincrement())
  token      String @unique
  documentId Int
  reviewerId Int

  version Int
  status  ApprovalTokenStatus @default(PENDING)

  expiredAt DateTime
  createdAt DateTime @default(now())

  @@index([documentId, reviewerId, version])
}