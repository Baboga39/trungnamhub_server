generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                  @id @default(autoincrement())
  name              String
  email             String               @unique
  password          String
  createdAt         DateTime             @default(now())
  role              String               @default("user")
  sumEvent          Int?
  startYear         DateTime?
  active            Boolean              @default(true)
  branch            String?
  activitiesCreated Activity[]
  activitiesMarked  ActivityAttendance[] @relation("MarkedBy")
  approvals         Approval[]
  attendancesMarked Attendance[]         @relation("MarkedBy")
  approvedDocuments Document[]           @relation("ApprovedBy")
  documents         Document[]
  gradeCategories   GradeCategory[]
  createdMembers    Member[]             @relation("MemberCreator")
  members           Member[]             @relation("MemberOwner")
  permissions       ScreenPermission[]
  sessionsCreated   Session[]

  @@index([role])
  @@index([active])
}

model Member {
  id                  Int                   @id @default(autoincrement())
  name                String
  birthDate           DateTime?
  gender              String?
  parish              String?
  church              String?
  startYear           Int?
  fatherName          String?
  motherName          String?
  address             String?
  promotionDate       DateTime?
  contact             String?
  active              Boolean               @default(true)
  createdAt           DateTime              @default(now())
  createdById         Int?
  updatedAt           DateTime              @updatedAt
  userId              Int?
  branch              String?
  startDate           DateTime?
  activityAttendances ActivityAttendance[]
  attendances         Attendance[]
  grades              Grade[]
  createdBy           User?                 @relation("MemberCreator", fields: [createdById], references: [id])
  user                User?                 @relation("MemberOwner", fields: [userId], references: [id])
  statusHistory       MemberStatusHistory[]

  @@index([userId])
  @@index([createdById])
  @@index([active])
}

model Attendance {
  id         Int      @id @default(autoincrement())
  date       DateTime
  memberId   Int
  createdAt  DateTime @default(now())
  markedById Int?
  note       String?
  sessionId  Int?
  status     String
  updatedAt  DateTime @updatedAt
  markedBy   User?    @relation("MarkedBy", fields: [markedById], references: [id])
  member     Member   @relation(fields: [memberId], references: [id])
  session    Session? @relation(fields: [sessionId], references: [id])

  @@unique([date, memberId])
  @@index([memberId])
  @@index([date])
}

model Grade {
  id            Int           @id @default(autoincrement())
  score         Float
  memberId      Int
  activityScore Float?
  categoryId    Int
  createdAt     DateTime      @default(now())
  quarter       Int
  year          Int
  category      GradeCategory @relation(fields: [categoryId], references: [id])
  mMember       Member        @relation(fields: [memberId], references: [id])

  @@unique([memberId, categoryId, year, quarter])
  @@index([memberId])
}

model GradeCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  weight      Float
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  createdById Int
  grades      Grade[]
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([createdById])
}

model ScreenPermission {
  id        Int      @id @default(autoincrement())
  screenId  String
  userId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([screenId, userId])
}

model Session {
  id          Int          @id @default(autoincrement())
  date        DateTime     @unique
  createdById Int
  createdAt   DateTime     @default(now())
  attendances Attendance[]
  createdBy   User         @relation(fields: [createdById], references: [id])

  @@index([createdById])
}

model Activity {
  id          Int                  @id @default(autoincrement())
  name        String
  description String?
  year        Int
  quarter     Int
  date        DateTime
  createdById Int
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  createdBy   User                 @relation(fields: [createdById], references: [id])
  attendances ActivityAttendance[]

  @@index([createdById])
  @@index([date])
}

model ActivityAttendance {
  id         Int      @id @default(autoincrement())
  status     String?
  note       String?
  activityId Int
  memberId   Int
  markedById Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  markedBy   User?    @relation("MarkedBy", fields: [markedById], references: [id])
  member     Member   @relation(fields: [memberId], references: [id])

  @@unique([activityId, memberId])
  @@index([memberId])
  @@index([activityId])
}

model MemberStatusHistory {
  id        Int      @id @default(autoincrement())
  memberId  Int
  note      String?
  createdAt DateTime @default(now())
  type      String? // ACTIVE | INACTIVE | PROMOTED

  date   DateTime
  status Boolean
  member Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

model Document {
  id             Int             @id @default(autoincrement())
  title          String
  fileUrl        String
  version        Int             @default(1)
  status         DocumentStatus  @default(PENDING)
  createdById    Int
  approvedById   Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  approvals      Approval[]
  approvalTokens ApprovalToken[]
  approvedBy     User?           @relation("ApprovedBy", fields: [approvedById], references: [id])
  createdBy      User            @relation(fields: [createdById], references: [id])

  @@index([status, createdAt])
  @@index([createdById])
}

model Approval {
  id         Int            @id @default(autoincrement())
  documentId Int
  reviewerId Int
  action     ApprovalAction
  comment    String?
  version    Int
  fileUrl    String
  createdAt  DateTime       @default(now())
  document   Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  reviewer   User           @relation(fields: [reviewerId], references: [id])

  @@index([documentId, version, action])
  @@index([documentId, createdAt])
}

model ApprovalToken {
  id         Int                 @id @default(autoincrement())
  token      String              @unique
  documentId Int
  reviewerId Int
  version    Int
  status     ApprovalTokenStatus @default(PENDING)
  expiredAt  DateTime
  createdAt  DateTime            @default(now())
  document   Document            @relation(fields: [documentId], references: [id])

  @@index([documentId, reviewerId, version])
}

model ReportSchedule {
  id             Int       @id @default(autoincrement())
  name           String
  templateId     String
  cronExpression String
  emails         Json
  parameters     Json      @default("{}")
  active         Boolean   @default(true)
  lastRunAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

enum DocumentStatus {
  PENDING
  NEED_REVISION
  APPROVED
}

enum ApprovalAction {
  APPROVE
  REJECT
  RESUBMIT
}

enum ApprovalTokenStatus {
  PENDING
  APPROVED
  REJECTED
}
